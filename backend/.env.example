# Runtime environment: sandbox | live
ENVIRONMENT=sandbox

# Port the API listens on (Railway injects PORT automatically)
PORT=8080

# Comma-separated origins allowed by CORS — add your Vercel URL after first deploy
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Injected automatically when you add the Redis plugin in Railway.
# Used by Nautilus live-mode cache/message-bus config (not needed for backtests).
REDIS_URL=redis://default:password@host:6379

# Exchange credentials for live/sandbox venue adapters (e.g. Binance testnet).
# Not needed for the backtest demo.
VENUE_API_KEY=your-venue-api-key
VENUE_SECRET=your-venue-api-secret

# Alpaca stock trading (paper account keys from https://app.alpaca.markets).
# Leave unset to disable the broker section of the dashboard.
ALPACA_API_KEY=your-alpaca-key-id
ALPACA_SECRET_KEY=your-alpaca-secret
# Only honored when ENVIRONMENT=live; otherwise always paper endpoint.
# ALPACA_BASE_URL=https://paper-api.alpaca.markets
